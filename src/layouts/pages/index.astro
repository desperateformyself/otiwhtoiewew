  <!-- Interactive Scripts -->
  <script is:inline>
    // ── 1. Sakura Falling Petals canvas ──────────────────────────────────────
    const canvas = document.getElementById("sakura-canvas");
    if (canvas) {
      const ctx = canvas.getContext("2d");
      let petals = [];
      let width = 0;
      let height = 0;
      let mouse = { x: -1000, y: -1000 };

      const resize = () => {
        width = canvas.offsetWidth;
        height = canvas.offsetHeight;
        canvas.width = width * window.devicePixelRatio;
        canvas.height = height * window.devicePixelRatio;
        ctx.scale(window.devicePixelRatio, window.devicePixelRatio);
      };

      window.addEventListener("resize", resize);
      resize();

      class Petal {
        constructor() {
          this.reset();
          this.y = Math.random() * height;
        }

        reset() {
          this.x = Math.random() * width;
          this.y = -10;
          this.size = Math.random() * 6 + 4;
          this.speedX = Math.random() * 1.5 - 0.5 + 0.3; // blow slightly right
          this.speedY = Math.random() * 0.8 + 0.6;
          this.angle = Math.random() * Math.PI * 2;
          this.spinSpeed = Math.random() * 0.02 - 0.01;
          this.sway = Math.random() * Math.PI;
          this.swaySpeed = Math.random() * 0.02 + 0.005;
        }

        update() {
          this.sway += this.swaySpeed;
          this.x += this.speedX + Math.sin(this.sway) * 0.25;
          this.y += this.speedY;
          this.angle += this.spinSpeed;

          // React to cursor
          const dx = mouse.x - this.x;
          const dy = mouse.y - this.y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 80) {
            const push = (80 - dist) * 0.08;
            this.x -= (dx / dist) * push;
            this.y -= (dy / dist) * push;
          }

          if (this.y > height + 10 || this.x < -10 || this.x > width + 10) {
            this.reset();
          }
        }

        draw() {
          ctx.save();
          ctx.translate(this.x, this.y);
          ctx.rotate(this.angle);
          ctx.beginPath();
          // Sakura blossom shape: two overlapping ellipses
          ctx.ellipse(0, 0, this.size, this.size / 2, 0, 0, Math.PI * 2);
          ctx.fillStyle = "rgba(236, 72, 153, 0.45)"; // Soft translucent pink
          ctx.fill();
          ctx.restore();
        }
      }

      // Initialize
      for (let i = 0; i < 35; i++) {
        petals.push(new Petal());
      }

      window.addEventListener("mousemove", (e) => {
        const rect = canvas.getBoundingClientRect();
        mouse.x = e.clientX - rect.left;
        mouse.y = e.clientY - rect.top;
      });

      window.addEventListener("mouseleave", () => {
        mouse.x = -1000;
        mouse.y = -1000;
      });

      const tick = () => {
        ctx.clearRect(0, 0, width, height);
        petals.forEach((p) => {
          p.update();
          p.draw();
        });
        requestAnimationFrame(tick);
      };
      tick();
    }

    // ── 2. Interactive Sandbox / Discord simulation ────────────────────────
    const warnSlider = document.getElementById("slider-warn");
    const warnVal = document.getElementById("warn-val");
    const automodToggle = document.getElementById("toggle-automod");
    const badwordsToggle = document.getElementById("toggle-badwords");
    const simButton = document.getElementById("trigger-test-btn");
    const discordChat = document.getElementById("discord-messages");
    const auditLogs = document.getElementById("live-audit-logs");

    if (warnSlider && warnVal) {
      warnSlider.addEventListener("input", (e) => {
        warnVal.textContent = e.target.value;
      });
    }

    const formatMessage = (text) => {
      return text.replace(/\*\*(.*?)\*\*/g, "<strong>$1</strong>");
    };

    // Discord message generator
    const addDiscordMessage = (
      author,
      content,
      isBot = false,
      isDeleted = false,
      embed = null,
    ) => {
      const msg = document.createElement("div");
      msg.className = `discord-msg ${isBot ? "lily-msg" : ""}`;

      const avatarClass = isBot ? "avatar-lily" : "avatar-user";
      const avatarText = isBot ? "🌸" : author[0].toUpperCase();
      const botBadge = isBot
        ? `<span class="discord-bot-badge">Bot</span>`
        : "";
      const timeStr = new Date().toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
      });

      let contentHtml = isDeleted
        ? `<span class="deleted-text">Message deleted by auto-mod (strike issued)</span>`
        : `<span class="discord-text">${formatMessage(content)}</span>`;

      let embedHtml = "";
      if (embed) {
        embedHtml = `
          <div class="discord-embed" style="max-width: 100%; width: 100%;">
            <div class="discord-embed-title">${embed.title}</div>
            <div class="discord-embed-desc">${embed.desc}</div>
          </div>
        `;
      }

      msg.innerHTML = `
        <div class="discord-avatar ${avatarClass}">${avatarText}</div>
        <div class="discord-msg-content" style="width: 100%;">
          <div class="discord-user-info">
            <span class="discord-username">${author}</span>
            ${botBadge}
            <span class="discord-time">Today at ${timeStr}</span>
          </div>
          ${contentHtml}
          ${embedHtml}
        </div>
      `;

      discordChat.appendChild(msg);
      discordChat.scrollTop = discordChat.scrollHeight;
    };

    // Audit logs terminal writer
    const addAuditLog = (type, action, message) => {
      const line = document.createElement("div");
      line.className = `log-line log-${type}`;

      const timeStr = new Date().toLocaleTimeString([], {
        hour: "2-digit",
        minute: "2-digit",
        second: "2-digit",
        hour12: false,
      });
      const tagClass = type;

      line.innerHTML = `
        <span class="log-time">[${timeStr}]</span>
        <span class="log-tag ${tagClass}">${action.toUpperCase()}</span>
        <span class="log-msg">${message}</span>
      `;

      auditLogs.appendChild(line);
      auditLogs.scrollTop = auditLogs.scrollHeight;

      // Restrict lines in logs
      while (auditLogs.childNodes.length > 20) {
        auditLogs.removeChild(auditLogs.firstChild);
      }
    };

    // User warning strikes memory
    let userStrikes = 0;
    const testUsers = [
      "TrollFace",
      "SpamKing",
      "ToxicGamer",
      "JohnDoe",
      "EmilyS",
    ];
    let customBadWords = ["ugly", "ez trash", "noobs"];
    const testSpam = [
      "FREE DISCORD NITRO!! JOIN HERE: discord.gg/scam-link",
      "GET FREE CRYPTO RIGHT NOW! https://bit.ly/scam-tokens",
    ];

    // Bad words tag system
    const tagsContainer = document.getElementById("badwords-tags");
    const badwordsInput = document.getElementById("badwords-input");

    const renderTags = () => {
      tagsContainer.innerHTML = "";
      customBadWords.forEach((word) => {
        const pill = document.createElement("span");
        pill.className = "tag-pill";
        pill.innerHTML = `${word} &times;`;
        pill.addEventListener("click", () => {
          customBadWords = customBadWords.filter((w) => w !== word);
          renderTags();
          addAuditLog("info", "config", `Removed custom word: "${word}"`);
        });
        tagsContainer.appendChild(pill);
      });
    };
    renderTags();

    if (badwordsInput) {
      badwordsInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") {
          e.preventDefault();
          const val = badwordsInput.value.trim().toLowerCase();
          if (val && !customBadWords.includes(val)) {
            customBadWords.push(val);
            renderTags();
            addAuditLog("success", "config", `Added custom word: "${val}"`);
            badwordsInput.value = "";
          }
        }
      });
    }

    if (simButton) {
      simButton.addEventListener("click", () => {
        const user = testUsers[Math.floor(Math.random() * testUsers.length)];
        const isSpam = Math.random() > 0.5;

        let rawMessage = "";
        if (isSpam) {
          rawMessage = testSpam[Math.floor(Math.random() * testSpam.length)];
        } else {
          const word =
            customBadWords.length > 0
              ? customBadWords[
                  Math.floor(Math.random() * customBadWords.length)
                ]
              : "friendly";
          rawMessage = `You all are so **${word}**!`;
        }

        // 1. User sends message
        addDiscordMessage(user, rawMessage);

        // 2. Lily processes message based on sandbox config
        setTimeout(() => {
          const automodOn = automodToggle.checked;
          const badwordsOn = badwordsToggle.checked;
          const threshold = parseInt(warnSlider.value);

          if (isSpam && automodOn) {
            // Delete spam
            addAuditLog(
              "warn",
              "automod",
              `Filtered spam link from user ${user}`,
            );

            // Delete message in mockup
            const lastMsg = discordChat.lastElementChild;
            const textSpan = lastMsg.querySelector(".discord-text");
            if (textSpan) {
              textSpan.className = "deleted-text";
              textSpan.textContent =
                "Message deleted by auto-mod (Anti-Spam Shield)";
            }

            userStrikes++;
            addAuditLog(
              "info",
              "strike",
              `${user} strike updated: ${userStrikes}/${threshold}`,
            );

            if (userStrikes >= threshold) {
              addDiscordMessage(
                "Lily",
                `⛔ **${user}** has been banned. Reason: Exceeded warning limit (${threshold}/${threshold})`,
                true,
              );
              addAuditLog(
                "error",
                "ban",
                `Auto-banned user ${user} (Exceeded limit: ${threshold}/${threshold})`,
              );
              userStrikes = 0; // reset
            } else {
              addDiscordMessage(
                "Lily",
                `⚠️ **${user}** has been warned for posting links. Warning count: **${userStrikes}/${threshold}**`,
                true,
              );
            }
          } else if (
            !isSpam &&
            badwordsOn &&
            customBadWords.some((w) => rawMessage.toLowerCase().includes(w))
          ) {
            // Delete bad word
            addAuditLog(
              "warn",
              "automod",
              `Profanity filtered from user ${user}`,
            );

            const lastMsg = discordChat.lastElementChild;
            const textSpan = lastMsg.querySelector(".discord-text");
            if (textSpan) {
              textSpan.className = "deleted-text";
              textSpan.textContent =
                "Message deleted by auto-mod (Profanity Filter)";
            }

            userStrikes++;
            addAuditLog(
              "info",
              "strike",
              `${user} strike updated: ${userStrikes}/${threshold}`,
            );

            if (userStrikes >= threshold) {
              addDiscordMessage(
                "Lily",
                `⛔ **${user}** has been banned. Reason: Exceeded warning limit (${threshold}/${threshold})`,
                true,
              );
              addAuditLog(
                "error",
                "ban",
                `Auto-banned user ${user} (Exceeded limit: ${threshold}/${threshold})`,
              );
              userStrikes = 0; // reset
            } else {
              addDiscordMessage(
                "Lily",
                `⚠️ **${user}** has been warned for using bad words. Warning count: **${userStrikes}/${threshold}**`,
                true,
              );
            }
          } else {
            // No action taken
            addAuditLog("success", "message", `Message approved from ${user}`);
          }
        }, 600);
      });
    }

    // Auto-running simulated background logs
    const mockFeedEvents = [
      {
        type: "info",
        act: "sys",
        msg: "Checking connection to Discord Gateway...",
      },
      {
        type: "success",
        act: "sys",
        msg: "Lily successfully logged in as: Lily#8024",
      },
      {
        type: "info",
        act: "guild",
        msg: 'Synced command cache for server: "Sakura Garden"',
      },
      {
        type: "success",
        act: "automod",
        msg: "Spam filters loaded successfully (34 rules active)",
      },
    ];

    mockFeedEvents.forEach((evt, idx) => {
      setTimeout(() => {
        addAuditLog(evt.type, evt.act, evt.msg);
      }, idx * 1000);
    });

    const loopLogs = () => {
      const actions = [
        {
          type: "info",
          act: "command",
          msg: 'Slash command "/warnings" executed by Mod#1234',
        },
        {
          type: "warn",
          act: "automod",
          msg: 'Invite link filter triggered in server "Dojo Devs"',
        },
        {
          type: "success",
          act: "unmute",
          msg: "User ToxicGuy#0011 unmute timer completed successfully",
        },
        {
          type: "info",
          act: "warn",
          msg: "Strike #1 issued to Troll#9234 by Admin (Reason: Off-topic spam)",
        },
      ];

      const randomAct = actions[Math.floor(Math.random() * actions.length)];
      addAuditLog(randomAct.type, randomAct.act, randomAct.msg);

      setTimeout(loopLogs, 7000 + Math.random() * 5000);
    };

    setTimeout(loopLogs, 5000);

    // ── 3. Discord Welcome Embed Creator ─────────────────────────────────────
    const embedTitleInput = document.getElementById("embed-title-input");
    const embedDescInput = document.getElementById("embed-desc-input");
    const embedColorInput = document.getElementById("embed-color-input");
    const embedColorHex = document.getElementById("embed-color-hex");

    const previewEmbedCard = document.getElementById("preview-embed-card");
    const previewEmbedTitle = document.getElementById("preview-embed-title");
    const previewEmbedDesc = document.getElementById("preview-embed-desc");

    const updateEmbedPreview = () => {
      if (previewEmbedTitle && embedTitleInput) {
        previewEmbedTitle.textContent =
          embedTitleInput.value || "Untitled Embed";
      }
      if (previewEmbedDesc && embedDescInput) {
        previewEmbedDesc.textContent = embedDescInput.value || "";
      }
      if (previewEmbedCard && embedColorInput) {
        const col = embedColorInput.value;
        previewEmbedCard.style.borderLeftColor = col;
        if (embedColorHex) {
          embedColorHex.textContent = col.toUpperCase();
        }
      }
    };

    if (embedTitleInput)
      embedTitleInput.addEventListener("input", updateEmbedPreview);
    if (embedDescInput)
      embedDescInput.addEventListener("input", updateEmbedPreview);
    if (embedColorInput)
      embedColorInput.addEventListener("input", updateEmbedPreview);

    // Initialize embed preview values on load
    updateEmbedPreview();

    // ── 4. FAQ Accordions ───────────────────────────────────────────────────
    const faqItems = document.querySelectorAll(".faq-item");
    faqItems.forEach((item) => {
      const question = item.querySelector(".faq-question");
      if (question) {
        question.addEventListener("click", () => {
          const isActive = item.classList.contains("active");

          // Close others
          faqItems.forEach((i) => i.classList.remove("active"));

          // Toggle current
          if (!isActive) {
            item.classList.add("active");
          }
        });
      }
    });

    // ── 5. Interactive Quote Card Generator ─────────────────────────────────
    const quoteTextVal = document.getElementById("quote-text-input");
    const quoteUserVal = document.getElementById("quote-username-input");
    const quoteUserIdVal = document.getElementById("quote-userid-input");
    const quoteColorVal = document.getElementById("quote-color-input");
    const quoteColorHexVal = document.getElementById("quote-color-hex");
    const quoteCanvas = document.getElementById("quote-card-canvas");
    const downloadBtn = document.getElementById("download-quote-btn");
    const avatarUpload = document.getElementById("quote-avatar-upload");
    const presetBtns = document.querySelectorAll(".preset-avatar");

    function generatePresetAvatar(type) {
      const c = document.createElement('canvas');
      c.width = 256;
      c.height = 256;
      const ctx = c.getContext('2d');
      if (type === 'lily') {
        ctx.fillStyle = '#fce7f3';
        ctx.fillRect(0, 0, 256, 256);
        ctx.font = '130px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('🌸', 128, 128);
      } else if (type === 'blue') {
        ctx.fillStyle = '#5865f2';
        ctx.fillRect(0, 0, 256, 256);
        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 120px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('M', 128, 134);
      } else if (type === 'green') {
        ctx.fillStyle = '#248046';
        ctx.fillRect(0, 0, 256, 256);
        ctx.fillStyle = '#ffffff';
        ctx.font = 'bold 120px sans-serif';
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText('S', 128, 134);
      }
      return c.toDataURL();
    }

    let currentAvatarDataUrl = generatePresetAvatar('lily');
    let selectedPreset = 'lily';
    let loadedAvatarImg = null;

    function loadAvatar(dataUrl, callback) {
      const img = new Image();
      img.onload = () => {
        loadedAvatarImg = img;
        if (callback) callback();
      };
      img.src = dataUrl;
    }

    // Avatar Presets Click Handler
    presetBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        presetBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        selectedPreset = btn.getAttribute('data-preset');
        currentAvatarDataUrl = generatePresetAvatar(selectedPreset);
        loadAvatar(currentAvatarDataUrl, drawQuoteCard);
      });
    });

    // Custom Avatar File Upload Handler
    if (avatarUpload) {
      avatarUpload.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
          const reader = new FileReader();
          reader.onload = (event) => {
            currentAvatarDataUrl = event.target.result;
            presetBtns.forEach(b => b.classList.remove('active'));
            selectedPreset = 'custom';
            loadAvatar(currentAvatarDataUrl, drawQuoteCard);
          };
          reader.readAsDataURL(file);
        }
      });
    }

    // Text wrapping function
    function wrapTextClient(ctx, text, maxWidth) {
      const words = text.split(/\s+/);
      const lines = [];
      let currentLine = '';

      for (let i = 0; i < words.length; i++) {
        const word = words[i];
        const testLine = currentLine ? `${currentLine} ${word}` : word;
        const width = ctx.measureText(testLine).width;

        if (width > maxWidth) {
          if (currentLine) {
            lines.push(currentLine);
          }
          currentLine = word;
        } else {
          currentLine = testLine;
        }
      }
      if (currentLine) {
        lines.push(currentLine);
      }
      return lines;
    }

    function drawQuoteCard() {
      if (!quoteCanvas) return;
      const ctx = quoteCanvas.getContext('2d');

      const text = quoteTextVal ? quoteTextVal.value : "You miss 100% of the shots you don't take. — Wayne Gretzky";
      const username = quoteUserVal ? quoteUserVal.value : "Michael Scott";
      const userId = quoteUserIdVal ? quoteUserIdVal.value : "1516374380710727750";
      const color = quoteColorVal ? quoteColorVal.value : "#ff9ecf";

      if (quoteColorHexVal) {
        quoteColorHexVal.textContent = color.toUpperCase();
      }

      // 1. Calculate dynamic wrapping and height
      const width = 1000;
      const paddingX = 60;
      const maxWidth = width - paddingX * 2;

      let fontSize = 28;
      ctx.font = `italic ${fontSize}px sans-serif`;
      let wrappedLines = wrapTextClient(ctx, text, maxWidth);

      if (wrappedLines.length > 5) {
        fontSize = 22;
        ctx.font = `italic ${fontSize}px sans-serif`;
        wrappedLines = wrapTextClient(ctx, text, maxWidth);
      }
      if (wrappedLines.length > 8) {
        fontSize = 18;
        ctx.font = `italic ${fontSize}px sans-serif`;
        wrappedLines = wrapTextClient(ctx, text, maxWidth).slice(0, 10);
      }

      const headerHeight = 170;
      const lineSpacing = fontSize * 1.35;
      const contentHeight = wrappedLines.length * lineSpacing;
      const footerHeight = 40;
      const height = Math.max(300, headerHeight + contentHeight + footerHeight);

      // Set canvas size (resizes layout dynamically)
      quoteCanvas.width = width;
      quoteCanvas.height = height;

      // Redefine font after resizing canvas since resizing resets state
      ctx.font = `italic ${fontSize}px sans-serif`;

      // 2. Draw Background Layer
      ctx.fillStyle = '#0f1012';
      ctx.fillRect(0, 0, width, height);

      // Extract colors for the gradient
      // Convert hex color to rgb
      const r = parseInt(color.slice(1, 3), 16);
      const g = parseInt(color.slice(3, 5), 16);
      const b = parseInt(color.slice(5, 7), 16);

      const radialGlow = ctx.createRadialGradient(width - 150, 150, 10, width - 150, 150, 500);
      radialGlow.addColorStop(0, `rgba(${r}, ${g}, ${b}, 0.22)`);
      radialGlow.addColorStop(1, 'rgba(0, 0, 0, 0)');
      ctx.fillStyle = radialGlow;
      ctx.fillRect(0, 0, width, height);

      // 3. Draw Glassmorphism Card Overlay
      const cardMargin = 20;
      const cardWidth = width - cardMargin * 2;
      const cardHeight = height - cardMargin * 2;

      ctx.fillStyle = 'rgba(24, 25, 28, 0.65)';
      ctx.beginPath();
      if (ctx.roundRect) {
        ctx.roundRect(cardMargin, cardMargin, cardWidth, cardHeight, 16);
      } else {
        ctx.rect(cardMargin, cardMargin, cardWidth, cardHeight);
      }
      ctx.fill();

      ctx.strokeStyle = 'rgba(255, 255, 255, 0.07)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      if (ctx.roundRect) {
        ctx.roundRect(cardMargin, cardMargin, cardWidth, cardHeight, 16);
      } else {
        ctx.rect(cardMargin, cardMargin, cardWidth, cardHeight);
      }
      ctx.stroke();

      // 4. Draw quotation mark decorations
      ctx.fillStyle = 'rgba(255, 255, 255, 0.035)';
      ctx.font = '240px Georgia, serif';
      ctx.fillText('“', 40, 240);
      ctx.fillText('”', width - 180, height - 60);

      // 5. Draw Avatar if preloaded
      if (loadedAvatarImg) {
        const avatarX = 50;
        const avatarY = 50;
        const avatarSize = 75;

        // Draw Avatar with clipping circular mask
        ctx.save();
        ctx.beginPath();
        ctx.arc(avatarX + avatarSize / 2, avatarY + avatarSize / 2, avatarSize / 2, 0, Math.PI * 2);
        ctx.clip();
        ctx.drawImage(loadedAvatarImg, avatarX, avatarY, avatarSize, avatarSize);
        ctx.restore();

        // White border ring on avatar
        ctx.strokeStyle = 'rgba(255, 255, 255, 0.1)';
        ctx.lineWidth = 2;
        ctx.beginPath();
        ctx.arc(avatarX + avatarSize / 2, avatarY + avatarSize / 2, avatarSize / 2, 0, Math.PI * 2);
        ctx.stroke();
      }

      // 6. Draw Username & Details
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 26px sans-serif';
      ctx.fillText(username, 50 + 75 + 20, 50 + 32);

      ctx.fillStyle = '#949ba4';
      ctx.font = '16px sans-serif';
      const formattedDate = new Date().toLocaleDateString('en-US', {
        month: 'short',
        day: 'numeric',
        year: 'numeric',
        hour: 'numeric',
        minute: '2-digit'
      });
      ctx.fillText(`ID: ${userId}  •  ${formattedDate}`, 50 + 75 + 20, 50 + 58);

      // 7. Draw Quote Text
      ctx.fillStyle = '#e3e5e8';
      ctx.font = `italic ${fontSize}px sans-serif`;
      ctx.textBaseline = 'top';

      let currentY = headerHeight - 20;
      for (const line of wrappedLines) {
        ctx.fillText(line, paddingX, currentY);
        currentY += lineSpacing;
      }
    }

    if (quoteTextVal) quoteTextVal.addEventListener('input', drawQuoteCard);
    if (quoteUserVal) quoteUserVal.addEventListener('input', drawQuoteCard);
    if (quoteUserIdVal) quoteUserIdVal.addEventListener('input', drawQuoteCard);
    if (quoteColorVal) quoteColorVal.addEventListener('input', drawQuoteCard);

    // Initial draw
    loadAvatar(currentAvatarDataUrl, drawQuoteCard);

    // Download Button Click Handler
    if (downloadBtn) {
      downloadBtn.addEventListener('click', () => {
        if (!quoteCanvas) return;
        const link = document.createElement('a');
        link.download = `quote-${Date.now()}.png`;
        link.href = quoteCanvas.toDataURL('image/png');
        link.click();
      });
    }
  </script>
