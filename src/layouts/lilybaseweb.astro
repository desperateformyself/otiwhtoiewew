
---
const { title = 'Lily', description = 'A gentle but powerful Discord moderation bot' } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=Playfair+Display:ital,wght@1,700&display=swap" rel="stylesheet" />
  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --white:      #ffffff;
      --blush:      #fdf2f8;
      --blush2:     #fce7f3;
      --pink-light: #fbcfe8;
      --pink:       #f9a8d4;
      --pink-mid:   #ec4899;
      --pink-deep:  #be185d;
      --text:       #1a0a12;
      --muted:      #9d6b85;
      --border:     #fce7f3;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--white);
      color: var(--text);
      font-family: 'DM Sans', system-ui, sans-serif;
      font-weight: 400;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    a { color: var(--pink-mid); text-decoration: none; }
    a:hover { color: var(--pink-deep); }

    /* ── Nav ─────────────────────────────────────────────────────────────── */
    nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2.5rem;
      height: 64px;
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
    }

    .nav-logo {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.5rem;
      color: var(--pink-mid);
      letter-spacing: -0.01em;
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 2rem;
    }

    .nav-links a {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--muted);
      transition: color 0.15s;
    }

    .nav-links a:hover { color: var(--pink-mid); }

    .nav-invite {
      background: var(--pink-mid);
      color: #fff !important;
      padding: 0.45rem 1.1rem;
      border-radius: 999px;
      font-size: 0.875rem !important;
      font-weight: 600 !important;
      transition: background 0.15s !important;
    }

    .nav-invite:hover { background: var(--pink-deep) !important; color: #fff !important; }

    /* ── Footer ──────────────────────────────────────────────────────────── */
    footer {
      text-align: center;
      padding: 2.5rem 2rem;
      border-top: 1px solid var(--border);
      color: var(--muted);
      font-size: 0.85rem;
      margin-top: 5rem;
      background: var(--blush);
    }

    footer span { color: var(--pink-mid); }
  </style>
</head>
<body>
  <nav>
    <span class="nav-logo">Lily</span>
    <div class="nav-links">
      <a href="/">Home</a>
      <a href="/commands">Commands</a>
      <a href="https://discord.com/oauth2/authorize?client_id=1516374380710727750&permissions=8&integration_type=0&scope=bot+applications.commands" target="_blank" class="nav-invite">Add to Discord</a>
    </div>
  </nav>

  <slot />

  <footer>
    <p>Made with <span>♥</span> · Lily &copy; {new Date().getFullYear()} · Built with discord.js</p>
  </footer>
</body>
</html>
