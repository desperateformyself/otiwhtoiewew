---
import Base from '../layouts/lilybaseweb.astro';

const commands = [
  // ── Moderation ──
  { 
    name: '/warn',   
    perm: 'Moderate Members', 
    category: 'moderation',
    desc: 'Issue a warning to a member. Logs to the database modlogs.',
    syntax: '/warn user: [user] reason: <reason>',
    output: {
      color: '#ff9ecf',
      title: 'User Warned',
      desc: '✅ **TrollFace#0001** has been warned.\n**Reason:** Spamming chat channels.'
    }
  },
  { 
    name: '/warnings',   
    perm: 'Everyone', 
    category: 'moderation',
    desc: 'Check a user\'s warning count and warning details.',
    syntax: '/warnings user: [user]',
    output: {
      color: '#ff9ecf',
      title: 'Warnings: TrollFace',
      desc: 'Total Warnings: **1**\n\nWarning #1\n**Reason:** Spamming chat channels.\n**Moderator:** Admin#0001'
    }
  },
  { 
    name: '/unwarn',   
    perm: 'Moderate Members', 
    category: 'moderation',
    desc: 'Remove a warning from a user by ID or clear their latest warning.',
    syntax: '/unwarn user: <user> id: <warning_id>',
    output: {
      color: '#ff9ecf',
      title: 'Warning Removed',
      desc: '✅ Removed the latest warning (#1) from **TrollFace#0001**.'
    }
  },
  { 
    name: '/nickname',   
    perm: 'Manage Nicknames', 
    category: 'moderation',
    desc: 'Change a member\'s nickname in the server.',
