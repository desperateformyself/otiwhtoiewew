---
import Base from '../layouts/lilybaseweb.astro';

const features = [
  { emoji: '🛡️', title: 'Auto-moderation',  desc: 'Spam detection, bad word filtering, and raid protection — quietly running in the background.' },
  { emoji: '⚠️', title: 'Warning system',    desc: 'Track strikes per user with configurable auto-escalation to kicks or bans.' },
  { emoji: '📋', title: 'Audit logging',     desc: 'Every mod action is logged to a channel and stored so nothing slips through.' },
  { emoji: '⚡', title: 'Slash commands',    desc: '/warn, /mute, /kick, /ban — clean and fast with permission checks built in.' },
  { emoji: '⚙️', title: 'Per-server config', desc: 'Set your log channel, warn threshold, and bad word list individually per server.' },
  { emoji: '🌸', title: 'Always online',     desc: 'Hosted on Railway with automatic restarts and zero downtime deploys.' },
];
---
<Base title="Lily — Discord Moderation">
  <style>
    /* ── Hero ──────────────────────────────────────────────────────────── */
    .hero {
      text-align: center;
      padding: 6rem 2rem 4rem;
      background: linear-gradient(180deg, var(--blush) 0%, var(--white) 100%);
      position: relative;
      overflow: hidden;
    }

    .hero::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 60% 40% at 20% 30%, #fce7f380 0%, transparent 70%),
        radial-gradient(ellipse 40% 30% at 80% 60%, #fbcfe840 0%, transparent 70%);
      pointer-events: none;
    }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--pink-mid);
      background: var(--blush2);
      border: 1px solid var(--pink-light);
      padding: 0.3rem 0.9rem;
      border-radius: 999px;
      margin-bottom: 1.75rem;
    }

    .hero h1 {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: clamp(3.5rem, 9vw, 6.5rem);
      font-weight: 700;
      line-height: 1.05;
      color: var(--text);
      letter-spacing: -0.02em;
      margin-bottom: 1.5rem;
    }

    .hero h1 em {
      font-style: italic;
      color: var(--pink-mid);
    }

    .hero p {
      color: var(--muted);
      font-size: 1.1rem;
      font-weight: 300;
      max-width: 480px;
      margin: 0 auto 2.5rem;
      line-height: 1.7;
    }

    .cta {
      display: inline-flex;
      gap: 0.875rem;
      flex-wrap: wrap;
      justify-content: center;
    }

    .btn {
      display: inline-block;
      padding: 0.8rem 2rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.95rem;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
    }

    .btn-primary {
      background: var(--pink-mid);
      color: #fff;
      box-shadow: 0 4px 20px #ec489940;
    }

    .btn-primary:hover {
      background: var(--pink-deep);
      box-shadow: 0 6px 24px #be185d50;
      color: #fff;
      transform: translateY(-1px);
    }

    .btn-ghost {
      background: #fff;
      color: var(--pink-mid);
      border: 1.5px solid var(--pink-light);
    }

    .btn-ghost:hover {
      border-color: var(--pink-mid);
      color: var(--pink-deep);
      transform: translateY(-1px);
    }

    /* ── Features ──────────────────────────────────────────────────────── */
    .features-section {
      padding: 5rem 2rem;
    }

    .section-label {
      text-align: center;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--pink-mid);
      margin-bottom: 0.75rem;
    }

    .section-title {
      text-align: center;
      font-size: clamp(1.6rem, 3vw, 2.25rem);
      font-weight: 600;
      color: var(--text);
      margin-bottom: 3rem;
      letter-spacing: -0.02em;
    }

    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.25rem;
      max-width: 960px;
      margin: 0 auto;
    }

    .card {
      background: var(--white);
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 1.75rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .card:hover {
      box-shadow: 0 8px 32px #f9a8d420;
      transform: translateY(-2px);
    }

    .card-icon {
      width: 44px;
      height: 44px;
      background: var(--blush2);
      border-radius: 12px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.3rem;
      margin-bottom: 1rem;
    }

    .card h3 {
      font-size: 1rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.4rem;
      letter-spacing: -0.01em;
    }

    .card p {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.6;
      font-weight: 300;
    }

    /* ── CTA banner ────────────────────────────────────────────────────── */
    .banner {
      margin: 0 2rem 2rem;
      background: linear-gradient(135deg, #fce7f3 0%, #fdf2f8 50%, #fce7f3 100%);
      border: 1px solid var(--pink-light);
      border-radius: 24px;
      padding: 4rem 2rem;
      text-align: center;
    }

    .banner h2 {
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.75rem;
      letter-spacing: -0.02em;
    }

    .banner p {
      color: var(--muted);
      font-weight: 300;
      margin-bottom: 2rem;
      font-size: 1rem;
    }
  </style>

  <section class="hero">
    <div class="hero-eyebrow">Discord moderation bot</div>
    <h1>Meet <em>Lily</em></h1>
    <p>Gentle on your server, firm on bad actors. Lily handles moderation automatically so you don't have to.</p>
    <div class="cta">
      <a class="btn btn-primary" href="https://discord.com/oauth2/authorize?client_id=1516374380710727750&permissions=8&integration_type=0&scope=applications.commands+bot" target="_blank">Add Lily to Discord</a>
      <a class="btn btn-ghost" href="/commands">View commands</a>
    </div>
  </section>

  <section class="features-section">
    <p class="section-label">Everything you need</p>
    <h2 class="section-title">Built for busy server owners</h2>
    <div class="features-grid">
      {features.map(f => (
        <div class="card">
          <div class="card-icon">{f.emoji}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <div class="banner">
    <h2>Ready to add Lily?</h2>
    <p>One click and she's in your server, protecting it around the clock.</p>
    <a class="btn btn-primary" href="https://discord.com/oauth2/authorize?client_id=1516374380710727750&permissions=8&integration_type=0&scope=applications.commands+bot" target="_blank">Invite Lily</a>
  </div>
</Base>
